# Core
BOT_TOKEN=your_bot_token
SUPERADMIN_IDS=123456789
BOT_USERNAME=YourBotUsername
BOT_DISPLAY_NAME=Growth Engine

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Deployment
PORT=10000
WEBHOOK_URL=https://your-app.onrender.com
USE_WEBHOOK=true

# Defaults
DEFAULT_REFERRAL_COINS=10
DEFAULT_BROADCAST_RATE=25
DEFAULT_APPROVE_RATE=2
MAX_FREE_CHANNELS=1
MAX_PREMIUM_CHANNELS=5
MAX_BUSINESS_CHANNELS=999

# Premium
PREMIUM_PRICE_MONTHLY=199
BUSINESS_PRICE_MONTHLY=499

# Clone
MAX_FREE_CLONES=0
MAX_PREMIUM_CLONES=1
MAX_BUSINESS_CLONES=5
CLONE_WEBHOOK_BASE_URL=https://your-app.onrender.com/clone
CLONE_ENCRYPTION_KEY=
